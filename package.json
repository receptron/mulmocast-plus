{
  "name": "mulmocast-plus",
  "version": "0.0.1",
  "description": "Monorepo for mulmocast-cli derivative packages",
  "private": true,
  "scripts": {
    "build": "yarn workspace @mulmocast/extended-types build && yarn workspace @mulmocast/script-utils build && yarn workspaces run build",
    "lint": "yarn workspaces run lint",
    "format": "yarn workspaces run format",
    "test": "yarn workspaces run test"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  },
  "resolutions": {
    "minimatch": "^10.2.2"
  },
  "author": "receptron",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "minimatch": "^10.2.2"
  }
}
