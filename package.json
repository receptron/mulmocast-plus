{
  "name": "mulmocast-plus",
  "version": "0.0.1",
  "description": "Monorepo for mulmocast-cli derivative packages",
  "private": true,
  "scripts": {
    "build": "yarn workspace @mulmocast/extended-types build && yarn workspace @mulmocast/script-utils build && yarn workspaces run build",
    "lint": "yarn workspaces run lint",
    "format": "yarn workspaces run format",
    "test": "yarn workspaces run test"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sonarjs": "^4.0.2",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  },
  "resolutions": {
    "minimatch": "^10.2.2"
  },
  "author": "receptron",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "minimatch": "^10.2.2"
  }
}
